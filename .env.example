# Copy to `.env.local` and fill in. Keep this file in sync with lib/env.ts.
# Server-only secrets have no prefix. Browser-exposed vars MUST start NEXT_PUBLIC_.

NODE_ENV=development

# --- MongoDB ---
# Reuse the same cluster you use for form-builder-portal; just change the DB name.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=treadhouse

# --- Better Auth ---
# Generate a secret:  npx @better-auth/cli@latest secret   (or: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Email (optional) ---
# Leave blank in dev — OTP codes are printed to the terminal instead of emailed.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# --- Cron (saved-search alerts) ---
# Shared secret for /api/cron/* (sent as the `x-cron-secret` header). When unset,
# the cron endpoints are disabled (503). Generate: openssl rand -hex 24
# CRON_SECRET=

# --- AI assistant (OpenRouter + Vercel AI SDK) ---
# Get a key at https://openrouter.ai/keys. When unset, the assistant API
# responds 503 and the chat widget hides itself (same pattern as S3/SendGrid).
# OPENROUTER_API_KEY=
# Optional overrides (defaults live in lib/env.ts):
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_FALLBACK_MODEL=anthropic/claude-3.5-haiku

# --- Voice (speech-to-text dictation + spoken replies) ---
# Reuses OPENROUTER_API_KEY above via OpenRouter's OpenAI-compatible audio
# endpoints — no separate key needed. Voice routes respond 503 (and the mic
# stays hidden/erroring) until OPENROUTER_API_KEY is set. Models are swappable:
# STT alternatives: openai/whisper-large-v3, groq/whisper-large-v3-turbo
# VOICE_STT_MODEL=openai/gpt-4o-mini-transcribe
# TTS: OpenAI TTS is NOT on OpenRouter. Default is Grok Voice (voices: Eve, Ara,
# Rex, Sal, Leo). If you change the model, change the voice to one it supports.
# Other models: google/gemini-3.1-flash-tts-preview, microsoft/mai-voice-2
# VOICE_TTS_MODEL=x-ai/grok-voice-tts-1.0
# VOICE_TTS_VOICE=Ara

# --- Browser-exposed ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
